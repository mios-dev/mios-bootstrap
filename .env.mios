# MiOS user-runtime defaults.
#
# This file is sourced by the installed MiOS environment as a fallback when
# /etc/mios/install.env or ~/.config/mios/env doesn't override a given key.
# It's user-space only -- build-time env lives in MiOS (Justfile / image-versions.yml).

# ============================================================================
# Account convention -- everything defaults to "mios" until the user overrides
# in the bootstrap install.sh prompts.
# ============================================================================
MIOS_DEFAULT_USER="mios"
MIOS_DEFAULT_HOST="mios"

# ============================================================================
# Inference backend (OpenAI-compatible)
# ============================================================================
MIOS_AI_ENDPOINT="http://localhost:8080/v1"
MIOS_AI_MODEL="default"

# ============================================================================
# Layered Flatpaks (applied at first-boot by the user-space ignition)
# ============================================================================
MIOS_FLATPAKS="org.gnome.Epiphany,com.github.tchx84.Flatseal,io.github.kolunmi.Bazaar,com.mattjakeman.ExtensionManager"

# ============================================================================
# Image / branch metadata (read-only; the system repo owns the canonical values)
# ============================================================================
MIOS_REPO_URL="https://github.com/MiOS-DEV/MiOS"
MIOS_BOOTSTRAP_REPO_URL="https://github.com/MiOS-DEV/MiOS-bootstrap"
MIOS_IMAGE_NAME="ghcr.io/kabuki94/mios"
MIOS_IMAGE_TAG="latest"
MIOS_BRANCH="main"
