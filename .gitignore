# MiOS-bootstrap allow-list. Bootstrap is a small, focused installer repo --
# only a handful of files belong here. Ignore everything, allow-list what
# bootstrap owns.
/*
.*

!README.md
!LICENSE
!VERSION
!install.sh
!install.ps1
!system-prompt.md

# User-space env templates and identity examples
!.env
!.env.mios
!identity.env.example
!image-versions.yml

# Repo hygiene
!.editorconfig
!.gitattributes
!.gitignore
!.github/
!.github/**

# Documentation (user-facing)
!USER-SPACE-GUIDE.md
!VARIABLES.md
!llms.txt

# Profile skeleton (dotfiles, per-user systemd units, system prompt, profile card)
!profile/
!profile/**

# Bootstrap-owned overlay subtrees that get merged into / on FHS hosts
# (system-prompt host copy, manifest, RAG, knowledge graphs, snapshots).
!etc/
!etc/**
!usr/
!usr/**
!var/
!var/**

# Re-ignore noise
**/__pycache__/
**/*.pyc
**/.DS_Store
**/Thumbs.db
