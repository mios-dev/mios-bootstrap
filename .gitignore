# MiOS-bootstrap allow-list. Bootstrap is a small, focused installer repo --
# only a handful of files belong here. Ignore everything, allow-list what
# bootstrap owns.
/*
.*

!README.md
!LICENSE
!VERSION
!bootstrap.sh
!bootstrap.ps1
!install.sh
!install.ps1
!build-mios.sh
!build-mios.ps1
!Get-MiOS.ps1
# Universal MiOS-SEED merge -- canonical bash + PowerShell implementations.
# Both build entries (build-mios.sh / build-mios.ps1) invoke these to
# overlay mios-bootstrap onto a mios.git checkout before podman build,
# so every Day-0 build produces an identical OCI image regardless of
# host platform. See AGREEMENTS.md and IMPLEMENTATION-SUMMARY.md.
!seed-merge.sh
!seed-merge.ps1
# Repo-root files. After the 2026-05-05 doc consolidation pass:
#   - duplicate substantive docs (AGREEMENTS, API, CREDITS) deleted from
#     bootstrap; consumers find them at mios.git canonicals.
#   - bootstrap-specific docs (AI, IMPLEMENTATION-SUMMARY, USER-SPACE-GUIDE,
#     VARIABLES) moved into usr/share/doc/mios-bootstrap/{concepts,guides,reference}/
#   - GitHub-convention + agent-tool discovery redirectors stay at root.
!AGENTS.md
!CLAUDE.md
!GEMINI.md
!system-prompt.md

# Single canonical user-edit dotfile (the one users actually edit).
# Every script in mios.git and mios-bootstrap.git resolves through this
# file via tools/lib/userenv.sh (in mios.git). Bootstrap stages this
# file to /etc/mios/mios.toml at install time; per-user copies are
# seeded from /etc/skel/.config/mios/mios.toml.
!mios.toml

# User-space env templates and identity examples
!.env
!.env.mios
!identity.env.example
!image-versions.yml

# Repo hygiene
!.editorconfig
!.gitattributes
!.gitignore
!.github/
!.github/**

# Agent identity dotfiles -- mirror MiOS so Cline/Cursor/Codex etc. resolve
# the same canonical system prompt (/usr/share/mios/ai/system.md) regardless
# of which repo they were invoked from.
!.clinerules
!.cursorrules

# Documentation (user-facing). The substantive bootstrap docs live under
# usr/share/doc/mios-bootstrap/ now; the cascade `!usr/` whitelist below
# tracks them automatically. Only the LLM-discovery file stays at root.
!llms.txt

# Bootstrap-owned overlay subtrees merged into / on FHS hosts and
# baked into the image on bootc. Per-user templates live under etc/skel
# (FHS standard skel directory -- populated into ~/<user>/ on useradd -m).
!etc/
!etc/**
!usr/
!usr/**
!var/
!var/**

# profile/ -- bootstrap profile staging area (Phase-3 contributor: writes
# ~/.config/mios/{profile.toml,system-prompt.md} per-user from these)
!profile/
!profile/**

# Re-ignore noise
**/__pycache__/
**/*.pyc
**/.DS_Store
**/Thumbs.db
