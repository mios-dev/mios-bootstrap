# MiOS-bootstrap allow-list. Bootstrap is a small, focused installer repo --
# only a handful of files belong here. Ignore everything, allow-list what
# bootstrap owns.
/*
.*

!README.md
!LICENSE
!VERSION
!install.sh
!install.ps1

# User-space env templates and identity examples
!.env
!.env.mios
!identity.env.example
!image-versions.yml

# Repo hygiene
!.editorconfig
!.gitattributes
!.gitignore
!.github/
!.github/**

# Documentation (user-facing)
!USER-SPACE-GUIDE.md
!VARIABLES.md
!llms.txt

# Profile skeleton (dotfiles, per-user systemd units, etc.)
!profile/
!profile/**

# Re-ignore noise
**/__pycache__/
**/*.pyc
**/.DS_Store
**/Thumbs.db
