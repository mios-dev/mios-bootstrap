# MiOS -- Force LF line endings for all text files.
# Bash scripts with CRLF break inside containers with "bad interpreter" errors.
# PowerShell files keep CRLF for Windows-native compatibility.
* text=auto eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.md text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.conf text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
