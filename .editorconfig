root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.sh]
indent_size = 4

[*.ps1]
end_of_line = crlf
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[Justfile]
indent_size = 4

[Containerfile]
indent_size = 4
